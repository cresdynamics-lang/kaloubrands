# Copy this file to .env and fill in your SMTP details to enable the contact form email.
PORT=3000

# Where contact form submissions are delivered
TO_EMAIL=info@kaloubrands.com

# SMTP credentials (e.g. from your email host, Gmail app password, Zoho, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-password

# Optional: the From header on outgoing mail
FROM_EMAIL="Kalou Brands Website <you@example.com>"
