# Copy this file to .env and fill in your SMTP password.
PORT=3000

# Where contact form submissions are delivered
TO_EMAIL=info@kaloubrands.com

# Namecheap Private Email SMTP
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=info@kaloubrands.com
SMTP_PASS=your-private-email-password

# Optional From header
FROM_EMAIL="Kalou Brands Website <info@kaloubrands.com>"
